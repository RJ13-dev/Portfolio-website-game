# Copy this file to `.env` and fill in real values. Never commit `.env`.

# --- Django ---
SECRET_KEY=replace-with-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Database (local Docker Postgres) ---
# In docker-compose this is set automatically; for local non-docker use:
DATABASE_URL=postgres://portfolio:portfolio@localhost:5432/portfolio

# --- Redis (leaderboard cache) ---
REDIS_URL=redis://localhost:6379/0

# --- Gemini chatbot ---
# Grab a key from https://aistudio.google.com/apikey and keep it out of git.
GEMINI_API_KEY=replace-me
GEMINI_MODEL=gemini-2.0-flash

# In production on Railway these are set in the service Variables tab, and
# DATABASE_URL / RAILWAY_PUBLIC_DOMAIN are injected automatically.
