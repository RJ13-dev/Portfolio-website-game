# Copy this file to `.env` and fill in real values. Never commit `.env`.

# --- Django ---
SECRET_KEY=replace-with-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Database (local Docker Postgres) ---
# In docker-compose this is set automatically; for local non-docker use:
DATABASE_URL=postgres://portfolio:portfolio@localhost:5432/portfolio

# --- Redis (leaderboard cache) ---
REDIS_URL=redis://localhost:6379/0

# --- Gemini AI chatbot ---
# Get your key from https://aistudio.google.com/apikey  -> never hardcode it
GEMINI_API_KEY=replace-me
GEMINI_MODEL=gemini-2.0-flash

# --- AWS (production: S3 static files + deploy) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=ap-southeast-2
USE_S3=False
